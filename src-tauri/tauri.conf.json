{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "usagedisk",
  "version": "0.1.0",
  "identifier": "com.dwirx.usagedisk",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun --hot src/server.ts",
    "beforeBuildCommand": "bun build ./src/index.html --outdir ./dist"
  },
  "app": {
    "windows": [
      {
        "title": "Dokter Storage C",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
